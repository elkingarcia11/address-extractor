{
  "manifest_version": 3,
  "name": "Text Extractor",
  "version": "1.0.0",
  "description": "Click or move with arrow keys to extract text from any element on the page.",
  "permissions": ["activeTab", "scripting", "sidePanel"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Text Extractor"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
